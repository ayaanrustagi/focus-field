{
  "manifest_version": 3,
  "name": "Focus Field — Block Distractions Browsing",
  "short_name": "Focus Field",
  "version": "1.1.1",
  "description": "Stay focused: block distracting sites during Pomodoro sessions (or always-on). Optional local webcam timelapse of your focus block. Settings stay on your device.",
  "homepage_url": "https://ayaanrustagi.github.io/focus-field/",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Focus Field",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "windows",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": ["<all_urls>"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "focus_block_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["content/blocked.html", "timelapse/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
